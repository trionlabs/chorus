# deployer wallet (funds contract deployment + committee registration)
DEPLOYER_PRIVATE_KEY=0x...

# base sepolia rpc (alchemy/infura or public)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# deployed contract address (set after deployment)
CONTRACT_ADDRESS=0x...

# frost keys directory (default: .frost)
FROST_KEYS_DIR=.frost

# uniswap api key (from developers.uniswap.org)
UNISWAP_API_KEY=

# synthesis hackathon api key
SYNTHESIS_API_KEY=
